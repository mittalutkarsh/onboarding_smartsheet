<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Git Onboarding Dashboard</title>
<style>
  /* Palette roles (dataviz reference palette). Only the roles used here. */
  .viz-root {
    --page:            #f9f9f7;
    --surface-1:       #fcfcfb;
    --text-primary:    #0b0b0b;
    --text-secondary:  #52514e;
    --muted:           #898781;
    --grid:            #e1e0d9;
    --border:          rgba(11,11,11,0.10);
    --track:           #eeeee9;
    /* status encoding (reserved status palette + neutral) */
    --st-new:          #898781;  /* neutral */
    --st-ready:        #2a78d6;  /* actionable */
    --st-prcreated:    #fab219;  /* in progress (warning) */
    --st-merged:       #0ca30c;  /* good */
    --st-blocked:      #d03b3b;  /* critical */
    --series-env:      #2a78d6;
  }
  @media (prefers-color-scheme: dark) {
    .viz-root {
      --page:           #0d0d0d;
      --surface-1:      #1a1a19;
      --text-primary:   #ffffff;
      --text-secondary: #c3c2b7;
      --muted:          #898781;
      --grid:           #2c2c2a;
      --border:         rgba(255,255,255,0.10);
      --track:          #2c2c2a;
      --st-new:         #898781;
      --st-ready:       #3987e5;
      --st-prcreated:   #fab219;
      --st-merged:      #0ca30c;
      --st-blocked:     #d03b3b;
      --series-env:     #3987e5;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--page); color: var(--text-primary);
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    font-size: 14px; line-height: 1.45;
  }
  .wrap { max-width: 1080px; margin: 0 auto; padding: 28px 20px 48px; }
  header { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  h1 { font-size: 20px; margin: 0; letter-spacing: -0.01em; }
  h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-secondary); margin: 0 0 12px; font-weight: 600; }
  .meta { color: var(--text-secondary); font-size: 12.5px; display: flex; gap: 14px; align-items: center; }
  .dot-live { width: 8px; height: 8px; border-radius: 50%; background: var(--st-merged); display: inline-block; margin-right: 5px; }
  .badge { border: 1px solid var(--border); border-radius: 999px; padding: 2px 10px; font-size: 12px; color: var(--text-secondary); }

  .card { background: var(--surface-1); border: 1px solid var(--border); border-radius: 12px; padding: 18px 18px 20px; }
  .grid-kpi { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin: 20px 0; }
  .grid-charts { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .grid-tables { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 820px) {
    .grid-kpi { grid-template-columns: repeat(2, 1fr); }
    .grid-charts, .grid-tables { grid-template-columns: 1fr; }
  }

  .kpi .label { font-size: 12px; color: var(--text-secondary); display: flex; align-items: center; gap: 6px; }
  .kpi .value { font-size: 30px; font-weight: 650; margin-top: 6px; letter-spacing: -0.02em; }
  .sdot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; flex: none; }

  /* horizontal bars (HTML marks: 2px gaps, 4px rounded data-end) */
  .bar-row { display: grid; grid-template-columns: 120px 1fr 34px; align-items: center; gap: 10px; margin: 9px 0; }
  .bar-row .name { font-size: 12.5px; color: var(--text-secondary); display: flex; align-items: center; gap: 7px; white-space: nowrap; }
  .track { background: var(--track); border-radius: 5px; height: 16px; overflow: hidden; }
  .fill { height: 100%; border-radius: 0 5px 5px 0; min-width: 2px; transition: width .4s ease; }
  .bar-row .num { text-align: right; font-variant-numeric: tabular-nums; font-size: 13px; color: var(--text-primary); }

  table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  th { text-align: left; color: var(--muted); font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; padding: 0 8px 8px; border-bottom: 1px solid var(--grid); }
  td { padding: 8px; border-bottom: 1px solid var(--grid); vertical-align: top; }
  tr:last-child td { border-bottom: none; }
  a { color: var(--st-ready); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .empty { color: var(--muted); padding: 14px 8px; font-style: italic; }
  .err { color: var(--st-blocked); }
  .status-pill { display: inline-flex; align-items: center; gap: 6px; }
</style>
</head>
<body class="viz-root">
  <div class="wrap">
    <header>
      <div>
        <h1>Git Onboarding Dashboard</h1>
        <div class="meta" style="margin-top:6px;">
          <span class="badge" id="source">source: …</span>
          <span><span class="dot-live"></span>auto-refresh {{ refresh_seconds }}s</span>
          <span id="updated">updated: …</span>
        </div>
      </div>
    </header>

    <section class="grid-kpi" id="kpis"></section>

    <section class="grid-charts">
      <div class="card">
        <h2>Onboarding status</h2>
        <div id="chart-status"></div>
      </div>
      <div class="card">
        <h2>Rows by environment</h2>
        <div id="chart-env"></div>
      </div>
    </section>

    <section class="grid-tables">
      <div class="card">
        <h2>Blocked / failed</h2>
        <div id="table-blocked"></div>
      </div>
      <div class="card">
        <h2>Open PRs</h2>
        <div id="table-prs"></div>
      </div>
    </section>
  </div>

<script>
const REFRESH_MS = {{ refresh_seconds }} * 1000;
// Data endpoint: "/api/data" for the live server, or a static "data.json" for
// the GitHub Pages export.
const DATA_URL = "{{ data_url | default('/api/data') }}";
const STATUS_ORDER = ["New", "Ready", "PR Created", "Merged", "Blocked"];
const STATUS_VAR = {
  "New": "--st-new", "Ready": "--st-ready", "PR Created": "--st-prcreated",
  "Merged": "--st-merged", "Blocked": "--st-blocked",
};
const cssVar = (name) => getComputedStyle(document.body).getPropertyValue(name).trim();
const esc = (s) => String(s == null ? "" : s).replace(/[&<>"]/g, c =>
  ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

function dot(varName) {
  return `<span class="sdot" style="background:${cssVar(varName)}"></span>`;
}

function renderKpis(k) {
  const tiles = [
    { label: "Total rows", value: k.total, v: null },
    { label: "Ready", value: k.ready, v: "--st-ready" },
    { label: "PR Created", value: k.pr_created, v: "--st-prcreated" },
    { label: "Merged", value: k.merged, v: "--st-merged" },
    { label: "Blocked", value: k.blocked, v: "--st-blocked" },
  ];
  document.getElementById("kpis").innerHTML = tiles.map(t => `
    <div class="card kpi">
      <div class="label">${t.v ? dot(t.v) : ""}${esc(t.label)}</div>
      <div class="value">${esc(t.value)}</div>
    </div>`).join("");
}

// Bars share one scale (max across the set) so lengths are comparable.
function renderBars(elId, rows, colorFn) {
  const max = Math.max(1, ...rows.map(r => r.count));
  const el = document.getElementById(elId);
  if (!rows.length) { el.innerHTML = `<div class="empty">No data.</div>`; return; }
  el.innerHTML = rows.map(r => {
    const pct = Math.round((r.count / max) * 100);
    const color = colorFn(r);
    const label = r.status ?? r.env;
    const swatch = r.status ? dot(STATUS_VAR[r.status] || "--muted") : "";
    return `
      <div class="bar-row" title="${esc(label)}: ${r.count}">
        <div class="name">${swatch}${esc(label)}</div>
        <div class="track"><div class="fill" style="width:${pct}%;background:${color}"></div></div>
        <div class="num">${r.count}</div>
      </div>`;
  }).join("");
}

function renderBlocked(rows) {
  const el = document.getElementById("table-blocked");
  if (!rows.length) { el.innerHTML = `<div class="empty">Nothing blocked. 🎉</div>`; return; }
  el.innerHTML = `<table><thead><tr><th>Team</th><th>Repo</th><th>Error</th></tr></thead><tbody>` +
    rows.map(r => `<tr>
      <td><span class="status-pill">${dot("--st-blocked")}${esc(r.team)}</span></td>
      <td>${esc(r.repo)}</td>
      <td class="err">${esc(r.error)}</td>
    </tr>`).join("") + `</tbody></table>`;
}

function renderPrs(rows) {
  const el = document.getElementById("table-prs");
  if (!rows.length) { el.innerHTML = `<div class="empty">No open PRs.</div>`; return; }
  el.innerHTML = `<table><thead><tr><th>Team</th><th>App</th><th>PR</th></tr></thead><tbody>` +
    rows.map(r => {
      const link = /^https?:\/\//.test(r.pr_url || "")
        ? `<a href="${esc(r.pr_url)}" target="_blank" rel="noopener">${esc(r.pr_url)}</a>`
        : esc(r.pr_url || "—");
      return `<tr><td>${esc(r.team)}</td><td>${esc(r.app)}</td><td>${link}</td></tr>`;
    }).join("") + `</tbody></table>`;
}

async function refresh() {
  try {
    const res = await fetch(DATA_URL, { cache: "no-store" });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const d = await res.json();
    document.getElementById("source").textContent = "source: " + d.source;
    document.getElementById("updated").textContent = "updated: " + d.generated_at;
    renderKpis(d.kpis);
    const statusRows = STATUS_ORDER
      .map(s => ({ status: s, count: (d.status_breakdown[s] || 0) }))
      .filter(r => r.count > 0);
    renderBars("chart-status", statusRows, r => cssVar(STATUS_VAR[r.status] || "--muted"));
    renderBars("chart-env", d.env_breakdown, () => cssVar("--series-env"));
    renderBlocked(d.blocked);
    renderPrs(d.open_prs);
  } catch (e) {
    document.getElementById("updated").textContent = "error: " + e.message;
  }
}
refresh();
setInterval(refresh, REFRESH_MS);
</script>
</body>
</html>
