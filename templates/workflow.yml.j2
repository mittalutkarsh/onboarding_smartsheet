# Rendered once per environment -> .github/workflows/deploy-{{ environment }}.yml
# Generated by onboarding-automation from the Smartsheet tracker. Do not edit by hand.
name: Deploy {{ app_name }} ({{ environment }})

on:
  workflow_dispatch:
  push:
    branches:
      - main

permissions:
  contents: read

jobs:
  deploy:
    name: Deploy {{ app_name }} to {{ environment }}
    runs-on: ubuntu-latest
    environment: {{ environment }}
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Deploy
        # Placeholder deploy step. Product team replaces this with the real
        # deployment for team "{{ team_name }}" ({{ github_org }}/{{ github_repo }}).
        run: |
          echo "Deploying app '{{ app_name }}' for team '{{ team_name }}'"
          echo "Target environment: {{ environment }}"
