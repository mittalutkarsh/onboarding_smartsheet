# Copy to `.env` and fill in. NEVER commit the real `.env`.
# Tokens are read from the environment only -- never hardcode them in code.

# Smartsheet API token (Account > Personal Settings > API Access).
SMARTSHEET_TOKEN=

# Numeric ID of the "Git Onboarding Tracker" sheet.  Placeholder: [SHEET_ID]
SMARTSHEET_SHEET_ID=

# GitHub token with repo + pull-request scope, used for git push and `gh`.
GITHUB_TOKEN=

# --- Optional ---
# Commit author identity for generated commits.
GIT_AUTHOR_NAME=onboarding-automation
GIT_AUTHOR_EMAIL=onboarding-automation@users.noreply.github.com

# Where target repos are checked out (defaults to a fresh temp dir per run).
# WORKSPACE_DIR=./.workspace

# Log verbosity (DEBUG shows gh/git commands).
# LOG_LEVEL=INFO
